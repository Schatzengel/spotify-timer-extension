{
  "manifest_version": 3,
  "name": "Spotify Web Timer",
  "version": "1.1",
  "description": "Timer untuk mematikan musik di Spotify Web secara otomatis.",
  "permissions": [
    "alarms",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://open.spotify.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}